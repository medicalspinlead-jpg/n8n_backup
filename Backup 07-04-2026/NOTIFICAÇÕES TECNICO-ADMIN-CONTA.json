      "parameters": {
        "jsCode": "const entrada = $input.all()[0].json.body;\n\n// normalização universal\nfunction normalizarTelefone(numero) {\n  if (!numero) return null;\n\n  let telefone = String(numero).replace(/\\D/g, '');\n\n  // remove 0 inicial\n  if (telefone.startsWith('0')) {\n    telefone = telefone.slice(1);\n  }\n\n  // adiciona DDI Brasil\n  if (!telefone.startsWith('55')) {\n    telefone = '55' + telefone;\n  }\n\n  return telefone;\n}\n\nconst usuario = entrada.usuario;\nconst empresa = entrada.empresa;\n\nreturn [\n  {\n    json: {\n      evento: entrada.evento,\n\n      usuario: {\n        id: usuario.id,\n        nome: usuario.nome,\n        email: usuario.email,\n        telefone: normalizarTelefone(usuario.telefone),\n        cargo: usuario.cargo\n      },\n\n      empresa: {\n        id: empresa.id,\n        nomeFantasia: empresa.nomeFantasia,\n        cnpj: empresa.cnpj,\n        cidade: empresa.cidade,\n        uf: empresa.uf,\n        telefone: normalizarTelefone(empresa.telefone),\n        email: empresa.email\n      },\n\n      aprovadoPor: entrada.aprovadoPor,\n      dataAprovacao: entrada.dataAprovacao\n    }\n  }\n];"
      },

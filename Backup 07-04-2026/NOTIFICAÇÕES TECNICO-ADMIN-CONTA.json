          "jsCode": "const entrada = $input.all()[0].json.body;\n\nconst tecnicos = entrada.usuariosNotificacao || [];\n\nfunction normalizarTelefone(numero) {\n  if (!numero) return null;\n\n  // remove tudo que não for número\n  let telefone = numero.replace(/\\D/g, '');\n\n  // se não começar com 55 → adiciona\n  if (!telefone.startsWith('55')) {\n    telefone = '55' + telefone;\n  }\n\n  return telefone;\n}\n\nconst resultado = tecnicos\n  .map(tecnico => {\n\n    const canaisAtivos = Object.entries(tecnico.canais || {})\n      .filter(([_, ativo]) => ativo === true)\n      .map(([canal]) => canal);\n\n    if (canaisAtivos.length === 0) return null;\n\n    return {\n      json: {\n        id: tecnico.id,\n        nome: tecnico.nome,\n        email: tecnico.email,\n        telefone: normalizarTelefone(tecnico.telefone),\n        canaisAtivos,\n        solicitacao: entrada.dados\n      }\n    };\n  })\n  .filter(Boolean);\n\nreturn resultado;"

    {
      "parameters": {
        "jsCode": "const mensagens = $json.mensagens;\n\n// filtra apenas mensagens do Lead\nconst mensagensLead = mensagens.filter(m => m.startsWith('Lead-'));\n\n// pega a última mensagem do Lead\nconst ultimaMensagem = mensagensLead[mensagensLead.length - 1];\n\n// extrai horário (último bloco após \"-\")\nconst partes = ultimaMensagem.split('-');\nconst horario = partes[partes.length - 1];\n\nconst [hora, minuto] = horario.split(':').map(Number);\n\n// hora atual Brasil\nconst agora = new Date();\n\nconst horaAtual = Number(\n  agora.toLocaleString('en-US', {\n    timeZone: 'America/Sao_Paulo',\n    hour: '2-digit',\n    hour12: false\n  })\n);\n\nconst minutoAtual = Number(\n  agora.toLocaleString('en-US', {\n    timeZone: 'America/Sao_Paulo',\n    minute: '2-digit'\n  })\n);\n\n// conversão em minutos\nconst minutosMensagem = hora * 60 + minuto;\nconst minutosAtual = horaAtual * 60 + minutoAtual;\n\n// diferença\nconst diferenca = minutosAtual - minutosMensagem;\n\nreturn [\n  {\n    json: {\n      ultimaMensagem,\n      horarioMensagem: horario,\n      diferencaMinutos: diferenca,\n      passou3Min: diferenca >= 3\n    }\n  }\n];"
      },

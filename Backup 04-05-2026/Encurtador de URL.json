      "parameters": {
        "html": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=5.0\">\n    \n    <title>Encurtador de URL - Ferramenta Gratuita</title>\n    \n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/bootstrap@4.4.1/dist/css/bootstrap.min.css\" \n          integrity=\"sha384-Vkoo8x4CGsO3+Hhxv8T/Q5PaXtkKtu6ug5TOeNV6gBiFeWPGFN9MuhOf23Q9Ifjh\" \n          crossorigin=\"anonymous\">\n    \n    <style>\n        :root {\n            --bg-light: #f8f9fa;\n            --text-light: #212529;\n            --bg-dark: #1a1d20;\n            --text-dark: #f8f9fa;\n        }\n\n        body {\n            min-height: 100vh;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            background: var(--bg-light);\n            color: var(--text-light);\n            line-height: 1.6;\n        }\n\n        .card {\n            width: 100%;\n            max-width: 768px;\n            border-radius: 12px;\n            box-shadow: 0 8px 30px rgba(0,0,0,0.12);\n            transition: transform 0.2s ease;\n        }\n\n        .card:hover {\n            transform: translateY(-2px);\n        }\n\n        .card-header {\n            background: rgba(0,123,255,0.1);\n            border-bottom: none;\n            font-size: 1.25rem;\n            font-weight: 600;\n        }\n\n        .form-control {\n            border-radius: 8px;\n            padding: 0.75rem 1rem;\n            transition: border-color 0.2s ease;\n        }\n\n        .btn-primary {\n            background-color: #007bff;\n            border: none;\n            border-radius: 8px;\n            padding: 0.75rem 1.5rem;\n            font-weight: 500;\n            transition: all 0.2s ease;\n        }\n\n        .btn-primary:hover {\n            background-color: #0056b3;\n            transform: translateY(-1px);\n        }\n\n        .card-text > a {\n            color: #007bff !important;\n            transition: opacity 0.2s ease;\n        }\n\n        .card-text > a:hover {\n            opacity: 0.8;\n            text-decoration: none;\n        }\n\n        #notice {\n            font-size: 0.875rem;\n            color: #6c757d;\n            text-align: center;\n            margin-top: 1rem;\n        }\n\n        @media (max-width: 768px) {\n            .card {\n                margin: 0 1rem;\n            }\n            \n            body {\n                padding: 1rem;\n            }\n        }\n\n        @media (prefers-color-scheme: dark) {\n            body {\n                background: var(--bg-dark);\n                color: var(--text-dark);\n            }\n            \n            .card {\n                background-color: #252d38;\n                border: 1px solid rgba(255,255,255,0.1);\n            }\n            \n            .form-control {\n                background-color: #2d3748;\n                border-color: #4a5568;\n                color: var(--text-dark);\n            }\n        }\n      .input-group {\n        align-items: stretch;\n    }\n\n    .form-control {\n        border-radius: 8px 0 0 8px;\n        padding: 0.675rem 1rem;\n        height: auto;\n    }\n\n    .btn-primary {\n        border-radius: 0 8px 8px 0;\n        padding: 0.675rem 1.25rem;\n        height: 100%;\n        white-space: nowrap;\n    }\n\n    .input-group-append {\n        height: auto;\n    }\n      #result {\n        background-color: #f8f9fa;\n        color: #212529;\n        border: 1px solid #ced4da;\n    }\n\n    /* Modo escuro */\n    @media (prefers-color-scheme: dark) {\n        #result {\n            background-color: #2d3748;\n            color: #e2e8f0;\n            border-color: #4a5568;\n        }\n        \n        #result:focus {\n            background-color: #2d3748;\n            color: #ffffff;\n            border-color: #63b3ed;\n        }\n    }\n</style\n</head>\n<body>\n    <div class=\"card\">\n        <div class=\"card-header\">🚀 Encurte suas URLs!</div>\n        <div class=\"card-body\">\n            <h5 class=\"card-title mb-4\">Insira sua URL longa abaixo:</h5>\n            \n            <div class=\"input-group mb-4\">\n                <input type=\"url\" \n                       class=\"form-control\" \n                       placeholder=\"https://exemplo.com/url-muito-longa...\"\n                       id=\"text\"\n                       aria-label=\"URL para encurtar\"\n                       required>\n                <div class=\"input-group-append\">\n                    <button class=\"btn btn-primary\" \n                            type=\"button\" \n                            id=\"searchbtn\"\n                            onclick=\"shorturl()\">\n                        Encurtar\n                    </button>\n                </div>\n            </div>\n            \n            <div class=\"card-text text-center mb-3\">\n                <a href=\"https://github.com/xyTom/Url-Shorten-Worker/\" \n                   target=\"_blank\"\n                   rel=\"noopener\"\n                   class=\"d-inline-flex align-items-center\">\n                    <svg width=\"1em\" height=\"1em\" viewBox=\"0 0 16 16\" class=\"bi bi-github mr-2\" fill=\"currentColor\" xmlns=\"http://www.w3.org/2000/svg\">\n                        <path fill-rule=\"evenodd\" d=\"M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z\"/>\n                    </svg>\n                    Fork no GitHub\n                </a>\n            </div>\n            \n            <p id=\"notice\" class=\"text-muted small\">Seus dados estão seguros conosco</p>\n        </div>\n    </div>\n\n    <!-- Modal -->\n    <div class=\"modal fade\" id=\"exampleModal\" tabindex=\"-1\" role=\"dialog\" aria-labelledby=\"exampleModalLabel\" aria-hidden=\"true\">\n        <div class=\"modal-dialog modal-dialog-centered\" role=\"document\">\n            <div class=\"modal-content\">\n                <div class=\"modal-header\">\n                    <h5 class=\"modal-title\" id=\"exampleModalLabel\">URL Encurtada</h5>\n                    <button type=\"button\" class=\"close\" data-dismiss=\"modal\" aria-label=\"Fechar\">\n                        <span aria-hidden=\"true\">&times;</span>\n                    </button>\n                </div>\n                <div class=\"modal-body\">\n                    <div class=\"input-group\">\n                        <input type=\"text\" \n                               class=\"form-control\" \n                               id=\"result\"\n                               readonly>\n                        <div class=\"input-group-append\">\n                            <button class=\"btn btn-outline-secondary\" \n                                    type=\"button\"\n                                    onclick=\"copyurl('result')\"\n                                    data-toggle=\"tooltip\"\n                                    title=\"Copiado!\">\n                                📋\n                            </button>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"modal-footer\">\n                    <button type=\"button\" class=\"btn btn-secondary\" data-dismiss=\"modal\">Fechar</button>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script src=\"https://code.jquery.com/jquery-3.4.1.slim.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/popper.js@1.16.0/dist/umd/popper.min.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/bootstrap@4.4.1/dist/js/bootstrap.min.js\"></script>\n\n    <script>\n        // Inicializa tooltips\n        $(function () {\n            $('[data-toggle=\"tooltip\"]').tooltip()\n        })\n\n        function shorturl() {\n            const urlInput = document.getElementById('text')\n            const url = urlInput.value.trim()\n\n            if (!url) {\n                alert('Por favor, insira uma URL válida')\n                urlInput.focus()\n                return\n            }\n\n            fetch('https://shorten.willianfernandes-ia.workers.dev', {\n                method: 'POST',\n                headers: { 'Content-Type': 'application/json' },\n                body: JSON.stringify({ url })\n            })\n            .then(response => {\n                if (!response.ok) throw new Error('Erro na requisição')\n                return response.json()\n            })\n            .then(data => {\n                const result = document.getElementById('result')\n                result.value = data.short_url || 'Erro ao encurtar URL'\n                $('#exampleModal').modal('show')\n            })\n            .catch(error => {\n                console.error('Error:', error)\n                document.getElementById('result').value = 'Erro no servidor'\n                $('#exampleModal').modal('show')\n            })\n        }\n\n        function copyurl(elementId) {\n            const copyText = document.getElementById(elementId)\n            copyText.select()\n            document.execCommand('copy')\n            \n            // Feedback visual\n            const copyBtn = document.querySelector('[data-toggle=\"tooltip\"]')\n            $(copyBtn).tooltip('show')\n            setTimeout(() => $(copyBtn).tooltip('hide'), 1000)\n        }\n    </script>\n</body>\n</html>"
      },

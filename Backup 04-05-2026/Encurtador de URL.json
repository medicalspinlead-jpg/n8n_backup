    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "=let res;\n\nfunction shorturl() {\n    let inputUrl = document.querySelector(\"#text\").value.trim();\n\n    if (inputUrl === \"\") {\n        alert(\"A URL não pode estar vazia!\");\n        return;\n    }\n\n    document.getElementById(\"searchbtn\").disabled = true;\n    document.getElementById(\"searchbtn\").innerHTML = \n        '<span class=\"spinner-border spinner-border-sm\" role=\"status\" aria-hidden=\"true\"></span> Aguarde...';\n\n    fetch(window.location.pathname, {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ url: inputUrl })\n    })\n    .then(response => response.json())\n    .then(data => {\n        res = data;\n        console.log(\"Resposta do Worker:\", res);\n\n        document.getElementById(\"searchbtn\").disabled = false;\n        document.getElementById(\"searchbtn\").innerHTML = 'Encurtar';\n\n        if (res.short_url) {\n            document.getElementById(\"result\").innerHTML = \n                `<a href=\"${res.short_url}\" target=\"_blank\">${res.short_url}</a>`;\n        } else {\n            document.getElementById(\"result\").innerHTML = \"Erro ao encurtar a URL.\";\n        }\n\n        $('#exampleModal').modal('show');\n    })\n    .catch(err => {\n        alert(\"Erro desconhecido. Por favor, tente novamente!\");\n        console.error(\"Erro ao processar:\", err);\n\n        document.getElementById(\"searchbtn\").disabled = false;\n        document.getElementById(\"searchbtn\").innerHTML = 'Encurtar';\n    });\n}\n\nfunction copyurl(id) {\n    let target = document.querySelector(`#${id}`);\n\n    if (!target) return;\n\n    try {\n        let range = document.createRange();\n        range.selectNode(target);\n        window.getSelection().removeAllRanges();\n        window.getSelection().addRange(range);\n        document.execCommand('copy');\n        window.getSelection().removeAllRanges();\n        console.log('Copiado com sucesso!');\n    } catch (e) {\n        console.log('Erro ao copiar');\n    }\n}\n\n$(function () {\n    $('[data-toggle=\"popover\"]').popover();\n});\n\nconsole.log(\"Repositório: https://github.com/xyTom/Url-Shorten-Worker/\");\n\nlet notice = \"Aviso: Este serviço é apenas para demonstração e os links curtos expiram automaticamente após 24 horas.\";\nif (window.location.host === \"lnks.eu.org\") {\n    document.getElementById(\"notice\").innerHTML = notice;\n}\n",
        "options": {
          "responseCode": 200
        }
      },

      {
        "parameters": {
          "jsCode": "// ===============================\n// CAPTURA EXECUÇÕES\n// ===============================\n\nconst executions = $input.all().map(i => i.json);\n\n// Últimos 30 dias\nconst now = new Date();\nconst last30Days = new Date();\nlast30Days.setDate(now.getDate() - 30);\n\n// Filtra execuções válidas\nconst recentExecutions = executions.filter(e => {\n  if (!e.startedAt || !e.stoppedAt) return false;\n\n  const started = new Date(e.startedAt);\n  return started >= last30Days && started <= now;\n});\n\n// ===============================\n// MÉTRICAS TÉCNICAS\n// ===============================\n\nconst totalExecutions = recentExecutions.length;\n\nconst failedExecutions = recentExecutions.filter(\n  e => e.status !== 'success'\n).length;\n\nconst failureRate =\n  totalExecutions === 0\n    ? 0\n    : (failedExecutions / totalExecutions) * 100;\n\n// Tempo médio de execução\nlet totalExecutionTimeMs = 0;\n\nrecentExecutions.forEach(e => {\n  const start = new Date(e.startedAt);\n  const end = new Date(e.stoppedAt);\n  totalExecutionTimeMs += (end - start);\n});\n\nconst avgExecutionTimeMs =\n  totalExecutions === 0\n    ? 0\n    : totalExecutionTimeMs / totalExecutions;\n\n// ===============================\n// TEMPO ECONOMIZADO\n// ===============================\n\nconst MINUTOS_ECONOMIZADOS_POR_EXECUCAO = 5;\n\nconst tempoEconomizadoMinutos =\n  totalExecutions * MINUTOS_ECONOMIZADOS_POR_EXECUCAO;\n\nconst tempoEconomizadoHoras =\n  tempoEconomizadoMinutos / 60;\n\n// ===============================\n// MÉTRICAS EXECUTIVAS\n// ===============================\n\nconst HORAS_DIA = 8;\nconst HORAS_MES = 160;\n\nconst funcionariosEquivalentes =\n  tempoEconomizadoHoras / HORAS_MES;\n\nconst diasTrabalhoEconomizados =\n  tempoEconomizadoHoras / HORAS_DIA;\n\nconst mesesHumanosEconomizados =\n  tempoEconomizadoHoras / HORAS_MES;\n\n// ===============================\n// OUTPUT FINAL\n// ===============================\n\nreturn [\n  {\n    json: {\n      periodo: \"ultimos_30_dias\",\n\n      // Execuções\n      execucoes_producao: totalExecutions,\n      execucoes_com_falha: failedExecutions,\n      taxa_falha_percentual: Number(failureRate.toFixed(2)),\n      tempo_medio_execucao_segundos:\n        Number((avgExecutionTimeMs / 1000).toFixed(2)),\n\n      // Tempo economizado\n      tempo_economizado_minutos: tempoEconomizadoMinutos,\n      tempo_economizado_horas:\n        Number(tempoEconomizadoHoras.toFixed(2)),\n\n      // Impacto operacional\n      funcionarios_equivalentes:\n        Number(funcionariosEquivalentes.toFixed(2)),\n\n      dias_trabalho_economizados:\n        Number(diasTrabalhoEconomizados.toFixed(0)),\n\n      meses_humanos_economizados:\n        Number(mesesHumanosEconomizados.toFixed(2)),\n    }\n  }\n];"
        },

    {
      "parameters": {
        "resource": "messages-api",
        "instanceName": "MedicalSpin",
        "remoteJid": "5579999801810",
        "messageText": "=🚀​INSIGHTS AUTOMAÇÕES MEDICAL SPIN🚀​\n\nPeríodos: {{ $json.periodo }}\nExecuções: {{ $json.execucoes_producao }}\nExecuções com falha: {{ $json.execucoes_com_falha }}\nTaxa de falhas: {{ $json.taxa_falha_percentual }}\nTempo médio de execuções: {{ $json.tempo_medio_execucao_segundos }}\nTempo economizado em minutos: {{ $json.tempo_economizado_minutos }}\nTempo economizado em horas: {{ $json.tempo_economizado_horas }}\n\n📈AUTOMAÇÃO X MANUAL📉\n\nFuncioários equivalentes: {{ Math.round($json.funcionarios_equivalentes) }}\n40h semanais ≈ 160h por mês\nCálculo\n{{ $json.tempo_economizado_horas }} ÷ 160 = {{ Math.round($json.funcionarios_equivalentes) }} funcioários\n\nDias de trabalho economizados: {{ $json.dias_trabalho_economizados }}\n8 horas\nCálculo\n{{ $json.tempo_economizado_horas }} ÷ 8 = {{ $json.dias_trabalho_economizados }} dias\n\nMeses economizados: {{ Math.round ($json.meses_humanos_economizados) }}\n160 horas ≈ mês corporativo médio\nCálculo\n{{ $json.tempo_economizado_horas }} ÷ 160 = {{ Math.round ($json.meses_humanos_economizados) }} meses",

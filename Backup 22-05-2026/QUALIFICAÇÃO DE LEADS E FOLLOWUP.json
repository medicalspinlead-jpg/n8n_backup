    {
      "parameters": {
        "jsCode": "const now = new Date();\n\nconst brazilHour = Number(\n  now.toLocaleString('en-US', {\n    timeZone: 'America/Sao_Paulo',\n    hour: '2-digit',\n    hour12: false\n  })\n);\n\nconst brazilMinute = Number(\n  now.toLocaleString('en-US', {\n    timeZone: 'America/Sao_Paulo',\n    minute: '2-digit'\n  })\n);\n\nconst isValidTime =\n  (brazilHour === 8 || brazilHour === 14) &&\n  brazilMinute === 0;\n\nreturn [\n  {\n    json: {\n      result: isValidTime ? 'sim' : 'não'\n    }\n  }\n];"
